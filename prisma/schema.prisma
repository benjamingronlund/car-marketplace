generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Country {
  DK
  SE
  NO
  FI
}

enum DealerStatus {
  active
  inactive
  pending
}

enum DealerTier {
  free
  starter
  pro
}

enum Currency {
  DKK
  SEK
  NOK
  EUR
}

enum FuelType {
  petrol
  diesel
  electric
  hybrid
  plug_in_hybrid
  hydrogen
}

enum Transmission {
  manual
  automatic
  semi_automatic
}

enum BodyType {
  sedan
  hatchback
  estate
  suv
  coupe
  convertible
  van
  pickup
}

enum Condition {
  new
  used
  demo
}

enum ListingStatus {
  draft
  active
  sold
  archived
}

enum UserRole {
  admin
  dealer_user
  buyer
}

enum Locale {
  da
  sv
  no
  fi
  en
}

enum LeadStatus {
  new
  contacted
  qualified
  closed_won
  closed_lost
}

enum LeadSource {
  listing_page
  chat
  phone_click
  email_click
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Dealer {
  id          String       @id @default(uuid())
  name        String       @db.VarChar(255)
  slug        String       @unique @db.VarChar(100)
  description String?      @db.Text
  logoUrl     String?      @db.VarChar(500)
  address     String?      @db.VarChar(255)
  city        String?      @db.VarChar(100)
  country     Country
  phone       String?      @db.VarChar(50)
  email       String       @db.VarChar(255)
  website     String?      @db.VarChar(500)
  status      DealerStatus @default(pending)
  tier        DealerTier   @default(free)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  listings Listing[]
  users    User[]
  leads    Lead[]

  @@map("dealers")
}

model Listing {
  id           String        @id @default(uuid())
  dealerId     String
  title        String        @db.VarChar(255)
  make         String        @db.VarChar(100)
  model        String        @db.VarChar(100)
  variant      String?       @db.VarChar(100)
  year         Int
  mileageKm    Int
  price        Decimal       @db.Decimal(12, 2)
  currency     Currency
  fuelType     FuelType
  transmission Transmission
  bodyType     BodyType
  colorExt     String?       @db.VarChar(100)
  colorInt     String?       @db.VarChar(100)
  condition    Condition
  vin          String?       @db.VarChar(17)
  images       Json          @default("[]")
  features     Json          @default("[]")
  description  String?       @db.Text
  status       ListingStatus @default(draft)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  dealer Dealer @relation(fields: [dealerId], references: [id])
  leads  Lead[]

  @@index([dealerId])
  @@index([status])
  @@index([make, model])
  @@map("listings")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique @db.VarChar(255)
  name      String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  role      UserRole @default(buyer)
  dealerId  String?
  locale    Locale   @default(en)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealer   Dealer?   @relation(fields: [dealerId], references: [id])
  leads    Lead[]
  accounts Account[]
  sessions Session[]

  @@index([dealerId])
  @@map("users")
}

model Lead {
  id         String     @id @default(uuid())
  listingId  String
  dealerId   String
  userId     String?
  guestName  String?    @db.VarChar(255)
  guestEmail String?    @db.VarChar(255)
  guestPhone String?    @db.VarChar(50)
  message    String     @db.Text
  status     LeadStatus @default(new)
  source     LeadSource
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  dealer  Dealer  @relation(fields: [dealerId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([dealerId])
  @@index([listingId])
  @@map("leads")
}

// ─── NextAuth / Auth.js tables ───────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
